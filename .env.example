# ── Google (Gemini Chat + Embeddings + Imagen) ──────────────
# Used for: chat routing, multimodal OCR, Gemini Embedding (text-embedding-004), Imagen 4
# Free tier embedding quota: 100 RPD / 30K tokens/day per key
# Add _1, _2, ... suffixes to register additional accounts and multiply quota.
GOOGLE_API_KEY=
GOOGLE_API_URL=
GOOGLE_API_KEY_1=
GOOGLE_API_URL_1=
GOOGLE_API_KEY_2=
GOOGLE_API_URL_2=

# ── GitHub Models ────────────────────────────────────────────
# Used for: GPT-4o, Grok-3, DeepSeek-R1 routing
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_API_URL=
GITHUB_MODELS_API_KEY_1=
GITHUB_MODELS_API_URL_1=
GITHUB_MODELS_API_KEY_2=
GITHUB_MODELS_API_URL_2=

# ── HuggingFace ──────────────────────────────────────────────
# Used for: FLUX.1-schnell, Stable Diffusion XL image generation
HUGGINGFACE_API_KEY=
HUGGINGFACE_API_URL=
HUGGINGFACE_API_KEY_1=
HUGGINGFACE_API_URL_1=
HUGGINGFACE_API_KEY_2=
HUGGINGFACE_API_URL_2=

# ── Free Provider (optional) ─────────────────────────────────
FREE_V36_API_KEY=
FREE_V36_API_URL=

# ── Ollama (local, no key required) ──────────────────────────
# Default: http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_API_URL=

# ── Server bind ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Security ─────────────────────────────────────────────────
# Set to 0 to allow remote access to /auth and /admin endpoints (default: 1 = localhost only)
AUTH_LOCAL_ADMIN_ONLY=1